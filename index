                <p style="margin-bottom:15px; color:#666; font-size:14px;">残念！合格にはミスを2問以下に抑える必要があります。もう一度覚え直して再挑戦しよう！</p>
                <button onclick="window.exitToListView()" class="btn-primary" style="width: 100%; height: 50px; background: #c62828; font-size:16px; border:none; border-radius:6px; font-weight:bold; box-shadow: 0 2px 5px rgba(198,40,40,0.1);">
                    👉 復習画面へ戻る
                </button>
            `;
        }
    } 
    // 🚀 【B】「今日の学習（最初の復習テスト）」ルートから来た場合
    else if (isFromTodayLesson) {
        let listHtml = "";
        testLog.forEach(item => {
            const mark = item.status === "correct" ? "○" : "×";
            const color = item.status === "correct" ? "#2e7d32" : "#c62828";
            listHtml += `<div style="color:${color}; border-bottom:1px solid #eee; padding:5px 0;">${mark} ${item.word} (${item.meaning})</div>`;
        });

        const isPerfect = (wrongWordsCount === 0);
        const titleText = isPerfect ? "✨ 復習テスト全問正解！ ✨" : "📖 復習テスト完了";
        const scoreText = isPerfect ? "完璧です！苦手克服！" : `${totalCount}問中 ${correctCount}問 正解`;
        const titleColor = isPerfect ? "#4caf50" : "#2196f3";

        resultView.innerHTML = `
            <h3 id="resultTitle" style="margin-top:0; color:${titleColor};">${titleText}</h3>
            <p id="resultScore" style="font-size:32px; font-weight:bold; margin:15px 0;">${scoreText}</p>
            <div id="resultList" style="text-align:left; max-height:150px; overflow-y:auto; border:1px solid #eee; padding:10px; margin-bottom:20px; font-size:14px; background:#fafafa;">${listHtml}</div>
            <p style="margin-bottom:15px; color:#666; font-size:14px;">次は本日の学習範囲【Section ${currentSection}】の暗記に進みます！</p>
            <button onclick="window.exitToListViewFromReview()" class="btn-primary" style="width: 100%; height: 50px; background: ${titleColor}; font-size:16px; border:none; border-radius:6px; font-weight:bold; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
                👉 本日の学習画面へ進む
            </button>
        `;
    } 
    // 📝 【C】練習用の「この範囲をテスト（青ボタン）」が終わった場合
    else if (isPracticeTest) {
        let listHtml = "";
        testLog.forEach(item => {
            const mark = item.status === "correct" ? "○" : "×";
            const color = item.status === "correct" ? "#2e7d32" : "#c62828";
            listHtml += `<div style="color:${color}; border-bottom:1px solid #eee; padding:5px 0;">${mark} ${item.word} (${item.meaning})</div>`;
        });

        resultView.innerHTML = `
            <h3 id="resultTitle" style="color:#9c27b0; margin-top:0;">📝 練習テスト結果</h3>
            <p id="resultScore" style="font-size:32px; font-weight:bold; margin:15px 0;">${totalCount}問中 ${correctCount}問 正解</p>
            <div id="resultList" style="text-align:left; max-height:150px; overflow-y:auto; border:1px solid #eee; padding:10px; margin-bottom:20px; font-size:14px; background:#fafafa;">${listHtml}</div>
            <p style="margin-bottom:15px; color:#666; font-size:14px;">間違えた単語を一覧でもう一度確認して覚え直しましょう！</p>
            <button onclick="window.exitToListView()" class="btn-primary" style="width: 100%; height: 50px; background: #9c27b0; font-size:16px; border:none; border-radius:6px; font-weight:bold; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
                👉 学習画面（一覧）に戻る
            </button>
        `;
    }
    
    window.currentCheckTestLength = undefined;
    window.isActualCheckTestMode = undefined;
}
