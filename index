function updateHomeDashboard() {
    const totalWords = words.length;
    const correctWords = words.filter(w => progress[w.word.toLowerCase()] === "correct").length;
    
    document.getElementById("studyCountText").textContent = studyCount;

    const totalSections = Math.ceil(totalWords / SECTION_SIZE);
    let completedCount = 0;
    for (let i = 1; i <= totalSections; i++) {
        const pool = words.slice((i-1)*SECTION_SIZE, i*SECTION_SIZE);
        if (pool.length > 0 && pool.every(w => progress[w.word.toLowerCase()] === "correct")) {
            completedCount++;
        }
    }
    const remainingSections = totalSections - completedCount;
    document.getElementById("remainingSectionsText").textContent = remainingSections;

    const progressPercent = totalWords > 0 ? (correctWords / totalWords) : 0;
    const circumference = 2 * Math.PI * 90;
    const offset = circumference - (progressPercent * circumference);
    const progressBar = document.getElementById("progressBar");
    if (progressBar) {
        progressBar.style.strokeDashoffset = offset;
    }

    if (document.getElementById("targetSectionName")) {
        document.getElementById("targetSectionName").textContent = isAllWordsMode ? "全単語（全範囲）" : `Section ${currentSection}`;
    }
}
  
