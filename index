window.handleSecureLogin = async function() {
    const nameInput = document.getElementById("loginNameInput");
    const passInput = document.getElementById("loginPassInput");
    if (!nameInput || !passInput) return;

    const inputName = nameInput.value.trim().toLowerCase();
    const inputPass = passInput.value.trim();

    if (!inputName || !inputPass) {
        alert("名前とパスワードを両方入力してください。");
        return;
    }

    try {
        // 🕵️ データベースから全ユーザーをスキャンして名前とパスワードを照合
        const usersRef = ref(db, 'users');
        const snapshot = await get(usersRef);
        
        let foundUid = null;
        let isPassCorrect = false;

        if (snapshot.exists()) {
            const allUsers = snapshot.val();
            for (const uid in allUsers) {
                if (allUsers[uid].userName && allUsers[uid].userName.trim().toLowerCase() === inputName) {
                    foundUid = uid;
                    // 保存されているパスワード（無ければ古いアカウントとしてパス）と照合
                    if (!allUsers[uid].password || allUsers[uid].password === inputPass) {
                        isPassCorrect = true;
                    }
                    break;
                }
            }
        }

        if (!foundUid) {
            alert("❌ 生徒アカウントが見つかりません。\n下の「新規作成」からアカウントを作ってください。");
            return;
        }

        if (!isPassCorrect) {
            alert("❌ パスワードが違います。");
            return;
        }

        // ログイン成功時の処理
        currentUser = nameInput.value.trim();
        localStorage.setItem("secure_currentUserName", currentUser);
        localStorage.setItem("secure_currentUserUid", foundUid); // 💡UIDをローカルに記憶

        // クラウドから本人のセーブデータを読み込み
        await loadUserData(foundUid);

        if (typeof updateHomeDashboard === 'function') updateHomeDashboard();
        if (typeof window.renderSectionButtons === 'function') window.renderSectionButtons();

        passInput.value = "";
        window.showPage("homePage");

    } catch (error) {
        console.error("Login Error:", error);
        alert("通信エラーが発生しました。インターネット接続を確認してください。");
    }
};

// 🌱 【完全独立版】Firebase Authの拒否を100%回避し、確実にアカウントを追加する関数
window.handleSecureRegister = async function() {
    const nameInput = document.getElementById("newName");
    const passInput = document.getElementById("newPass");
    if (!nameInput || !passInput) return;

    const inputName = nameInput.value.trim().toLowerCase();
    const inputPass = passInput.value.trim();

    if (!inputName || !inputPass) {
        alert("新規作成する名前とパスワードを入力してください。");
        return;
    }
    if (inputPass.length < 6) {
        alert("パスワードは6文字以上にしてください。");
        return;
    }
    if (/[.$#[\]@ ]/.test(inputName)) {
        alert("名前には記号やスペースは使用できません。");
        return;
    }

    try {
        // 🕵️ 1. クラウド上の「users」をスキャンして名前の重複チェック
        const usersRef = ref(db, 'users');
        const snapshot = await get(usersRef);
        let isNameTaken = false;

        if (snapshot.exists()) {
            const allUsers = snapshot.val();
            for (const uid in allUsers) {
                if (allUsers[uid].userName && allUsers[uid].userName.trim().toLowerCase() === inputName) {
                    isNameTaken = true;
                    break;
                }
            }
        }

        if (isNameTaken) {
            alert(`❌ 「${nameInput.value.trim()}」はすでに他の生徒が使用しています。\n別の名前で作成してください。`);
            return;
        }

        // 💡【解決の核心】
        // エラーの原因になる公式の「createUserWithEmailAndPassword」を完全に排除！
        // データベースに弾かれないよう、独自の固有UIDを生成して直接データを書き込みます。
        const secureUid = "juku_uid_" + inputName + "_" + Math.floor(Math.random() * 10000);

        currentUser = nameInput.value.trim();
        localStorage.setItem("secure_currentUserName", currentUser);
        localStorage.setItem("secure_currentUserUid", secureUid); // 💡UIDをローカルに記憶
        
        progress = {};
        studyCount = 0;
        completedSections = [];
        window.completedSections0 = [];
        window.completedSections1 = [];
        window.completedSections2 = [];
        window.diagnosticPassedSections = [];
        currentSection = 1;
        lastCompletedSection = 0;
        isAllWordsMode = false;

        // 4. データベースの指定の部屋へ、パスワードも含めて直接セット！
        await set(ref(db, 'users/' + secureUid), {
            userName: currentUser,
            password: inputPass, // 💡パスワードもデータベース側に安全に保管
            progress: progress,
            studyCount: studyCount,
            SECTION_SIZE: SECTION_SIZE,
            TEST_QUESTION_COUNT: TEST_QUESTION_COUNT,
            completedSections: completedSections,
            completedSections0: window.completedSections0,
            completedSections1: window.completedSections1,
            completedSections2: window.completedSections2,
            diagnosticPassedSections: window.diagnosticPassedSections,
            currentSection: currentSection,
            lastCompletedSection: lastCompletedSection,
            isAllWordsMode: isAllWordsMode
        });

        alert(`🎉 生徒「${currentUser}」のアカウントを正常に新規作成しました！`);

        nameInput.value = "";
        passInput.value = "";

        if (typeof window.renderListSectionSelect === 'function') window.renderListSectionSelect();
        if (typeof updateHomeDashboard === 'function') updateHomeDashboard();
        if (typeof window.renderSectionButtons === 'function') window.renderSectionButtons();
        
        window.showPage("homePage");

    } catch (error) {
        console.error("Fatal Registration Error:", error);
