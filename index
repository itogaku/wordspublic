            document.getElementById("diagnosticDirectHomeBackBtn").onclick = () => {
                isDiagnosticMode = false;
                isReviewMode = false;
                try { if (typeof saveProgress === 'function') saveProgress(); } catch(e) { console.error(e); }
                if (typeof updateHomeDashboard === 'function') updateHomeDashboard();
                window.showPage("homePage");
            };
        }

        window.currentCheckTestLength = undefined;
        window.isActualCheckTestMode = undefined;
        return;
    }
    // ========================================================
    // 📝 以下の通常リザルト処理（A〜D）
    // ========================================================
    document.getElementById("quizQuestionArea").classList.add("hidden");
    document.getElementById("answerControlArea").classList.add("hidden");
    document.getElementById("quizKeyboard").classList.add("hidden");
    document.getElementById("quizResultView").classList.remove("hidden");

    const quizBottomBackBtn = document.querySelector("#quiz > div > button[onclick='goBackToListFromQuiz()']");
    if (quizBottomBackBtn && quizBottomBackBtn.parentElement) {
        quizBottomBackBtn.parentElement.style.display = "none";
    }

    const totalCount = testLog.length;
    const wrongWordsCount = testLog.filter(i => i.status === "wrong").length; // 💡ミスした数を数える
    const correctCount = totalCount - wrongWordsCount;

    const resultView = document.getElementById("quizResultView");

    const isPracticeTest = (isSelfPracticeMode === true);
    const isCheckTest = (window.isActualCheckTestMode === true);
    const isFromTodayLesson = (window.isTodayReviewTestMode === true);

    // 🏆 【A】本番のチェックテスト（赤ボタン）の合格判定処理（2問ミスまで合格）
    if (isCheckTest && !isPracticeTest && !isFromTodayLesson && !isAllWordsMode) {
        
        if (wrongWordsCount <= 2) { // 🎯 2問ミス以下なら合格！
            reviewWrongWords = []; 

            // 💡 記録用の配列がなければ初期化
            if (!window.completedSections0) window.completedSections0 = [];
            if (!window.completedSections1) window.completedSections1 = [];
            if (!window.completedSections2) window.completedSections2 = [];

            // 💡 ミス数に応じたフォルダにセクションを記録（重複を避けて追加）
            if (wrongWordsCount === 0) {
                if (!window.completedSections0.includes(currentSection)) window.completedSections0.push(currentSection);
            } else if (wrongWordsCount === 1) {
                if (!window.completedSections1.includes(currentSection)) window.completedSections1.push(currentSection);
            } else if (wrongWordsCount === 2) {
                if (!window.completedSections2.includes(currentSection)) window.completedSections2.push(currentSection);
            }

            if (!completedSections.includes(currentSection)) {
                completedSections.push(currentSection);
            }
            lastCompletedSection = currentSection;

            const maxSection = Math.ceil(words.length / SECTION_SIZE);
            if (currentSection < maxSection) {
                currentSection = currentSection + 1; 
            }
            
            const user = auth.currentUser;
            if (user) {
                update(ref(db, 'users/' + user.uid), {
                    currentSection: currentSection,
                    completedSections: completedSections,
                    completedSections0: window.completedSections0,
                    completedSections1: window.completedSections1,
                    completedSections2: window.completedSections2,
                    lastCompletedSection: lastCompletedSection,
