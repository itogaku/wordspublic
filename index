    // 🚀 実力診断テストを「ステージ1（中1）」から開始する関数
window.startDiagnosticTest = function() {
    if (!words || words.length === 0) return;
    
    // 💡【解決の核心2】過去の合格状況（緑・黄・青）から、クリア済みの学年を判定
    if (!window.completedSections0) window.completedSections0 = [];
    if (!window.completedSections1) window.completedSections1 = [];
    if (!window.completedSections2) window.completedSections2 = [];
    if (!window.diagnosticPassedSections) window.diagnosticPassedSections = [];

    // 各学年の全セクションが合格しているかチェックする補助関数
    const isStageAllCleared = (startSec, endSection) => {
        for (let s = startSec; s <= endSection; s++) {
            const hasPassed = window.completedSections0.includes(s) || 
                              window.completedSections1.includes(s) || 
                              window.completedSections2.includes(s) || 
                              window.diagnosticPassedSections.includes(s);
            if (!hasPassed) return false; // 1つでも未クリアがあればその学年は未クリア
        }
        return true;
    };

    let startStage = 1; // デフォルトは中1
    
    // 中1（1〜22）が全部クリア済みなら、ステージ2（中2）へ
    if (isStageAllCleared(1, 22)) {
        startStage = 2;
        // さらに中2（23〜53）も全部クリア済みなら、ステージ3（中3）へ
        if (isStageAllCleared(23, 53)) {
            startStage = 3;
            // もし中3（54〜74）まで全部終わっていたら、テスト不要
            if (isStageAllCleared(54, 74)) {
                alert("🎉 中1〜中3のすべてのクラスがすでにクリアされています！実力診断テストを受ける必要はありません。");
                return;
            }
        }
    }

    // 診断モードの起動設定
    isDiagnosticMode = true;
    isReviewMode = true; 
    isSelfPracticeMode = false;
    window.isActualCheckTestMode = false;
    window.isTodayReviewTestMode = false;
    
    // スキップを反映したステージから開始！
    diagnosticStage = startStage;
    diagnosticStageCorrect = 0;
    testLog = [];
    studyCount++;
    
    // 該当ステージの問題プールを生成
    generateDiagnosticPoolForStage(diagnosticStage);
    
    renderQuestion();
    window.showPage("quiz");
};
// 📦 各ステージに応じた問題プール（10問）を生成する内部関数
function generateDiagnosticPoolForStage(stage) {
    let stageWords = [];
    
    if (stage === 1) {
        // 中1範囲 (1語目〜219語目)
        stageWords = words.slice(0, 219);
    } else if (stage === 2) {
        // 中2範囲 (220語目〜532語目)
        stageWords = words.slice(219, 532);
    } else {
        // 中3範囲 (533語目〜735語目)
        stageWords = words.slice(532, 735);
    }
    
    // 💡 元の配列を傷つけないようにコピーしてシャッフルし、確実に10問だけを reviewPool にセット
    reviewPool = [...stageWords].sort(() => 0.5 - Math.random()).slice(0, 10);
}
// 🏁 ステージごとの合否判定と、最終スタート位置を決定する関数
function handleDiagnosticStageClear() {
    const passThreshold = 8;
    // 今回の10問中、何問正解したかを正確にカウント
    const stageCorrectCount = testLog.filter(i => i.status === "correct").length;
    const isStagePassed = (stageCorrectCount >= passThreshold);

    if (isStagePassed && diagnosticStage < 3) {
        // ========================================================
        // 🟢 【合格】次のステージの10問をセットして画面を切り替える
        // ========================================================
        diagnosticStage++; // ステージを1つ進める (1→2、または2→3)
        diagnosticStageCorrect = 0;
        testLog = []; // ログを次のステージ用に一回復活リセット

        // 🎯 既存の関数を使って、次のステージの10問を reviewPool に強制再セット！
        generateDiagnosticPoolForStage(diagnosticStage);
        
        // 📝 既存のUIリセット関数を叩いて、画面を綺麗なクイズ状態に戻す
        if (typeof resetQuizUI === 'function') resetQuizUI();
        
        // 💡【塾用制限の復活】最初の復習テスト時と同じく、診断テスト中も「一覧に戻る」ボタンを隠す
        const quizBottomBackBtn = document.querySelector("#quiz > div > button[onclick='goBackToListFromQuiz()']");
        if (quizBottomBackBtn && quizBottomBackBtn.parentElement) {
            quizBottomBackBtn.parentElement.style.display = "none";
        }

        // 💥 既存の描画関数を叩いて、次のステージの1問目を表示して即開始！
        renderQuestion();
        
    } else {
        // ========================================================
        // 🔴 【不合格】または【全クリア】で終了する場合（直でホームに戻る）
        // ========================================================
        isDiagnosticMode = false;
        isReviewMode = false;

        // 最終的な判定レベルを計算
        let finalLevelKey = "chui1";
        if (isStagePassed && diagnosticStage === 3) {
            finalLevelKey = "saijoi";
        } else {
            if (diagnosticStage === 1) finalLevelKey = "chui1";
            else if (diagnosticStage === 2) finalLevelKey = "chui2";
            else finalLevelKey = "chui3";
        }

        // 既存の確定関数にバトンタッチして直でホームへ戻る
        if (typeof setFinalDiagnosticLevel === 'function') {
            setFinalDiagnosticLevel(finalLevelKey);
        } else {
            window.showPage("homePage");
        }
    }
}
// 💾 最終的な判定クラスを確定させてデータを保存し、ホームへ戻す関数
async function setFinalDiagnosticLevel(levelKey) {
    isDiagnosticMode = false;
    isReviewMode = false; 
    
    let recommendedIndex = 0;
    if (levelKey === "chui1") recommendedIndex = 0;
    else if (levelKey === "chui2") recommendedIndex = 219;
    else if (levelKey === "chui3") recommendedIndex = 532;
    else if (levelKey === "saijoi") recommendedIndex = 735;

    // 生徒の progress を、おすすめの位置の手前まで自動的に「合格（correct）」にする
    for (let i = 0; i < recommendedIndex; i++) {
        const w = words[i];
        if (w && w.word) progress[w.word.toLowerCase()] = "correct"; 
    }
    
    // 💡【新規追加】診断テストによって合格（スキップ）扱いになったセクションを自動計算して記録
    window.diagnosticPassedSections = [];
    const targetSection = Math.floor(recommendedIndex / 10) + 1;
    for (let s = 1; s < targetSection; s++) {
        if (!window.diagnosticPassedSections.includes(s)) {
            window.diagnosticPassedSections.push(s);
        }
    }
    currentSection = targetSection;

    // バックグラウンドで保存
    try {
        if (typeof saveProgress === 'function') saveProgress();
    } catch (error) {
        console.error(error);
    }

    if (typeof updateHomeDashboard === 'function') updateHomeDashboard();
    window.showPage("homePage");
}
    
