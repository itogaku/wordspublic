window.deleteCurrentUserAccount = async function() {
    const user = auth.currentUser;
    if (!user) return alert("ログイン中のユーザー情報が見つかりません。");

    const confirm1 = confirm(`【重大な警告】\n現在ログイン中の生徒「 ${currentUser} 」のアカウントを完全に削除しますか？\nこの操作は取り消せません。`);
    if (!confirm1) return;

    const confirm2 = confirm(`本当に本当によろしいですか？\nクラウド上のパスワード、合格履歴、すべての学習ログ、苦手単語データが完全に消去され、元に戻せなくなります。`);
    if (!confirm2) return;

    try {
        const deletedUid = user.uid;
        const deletedName = currentUser;

        // 1. クラウド上の本人の部屋と名簿インデックスを完全削除
        await set(ref(db, 'users/' + deletedUid), null);
        await set(ref(db, 'public_users/' + deletedName.toLowerCase()), null);

        // 2. Auth（認証基盤）からアカウントそのものを抹消
        await deleteUser(user);

        // 3. キャッシュの初期化
        localStorage.removeItem("secure_currentUserName");
        currentUser = null;
        progress = {};
        studyCount = 0;
        reviewWrongWords = [];
        completedSections = [];
        currentSection = 1;

        alert(`生徒「 ${deletedName} 」のアカウントを完全に消去しました。`);
        await window.renderUserList();
        window.showPage("userPage");
    } catch (e) {
        console.error("Account Delete Error:", e);
        alert("安全上の理由により、長期間再ログインしていないアカウントは即座に削除できません。一度ログアウトし、再ログインしてから再度削除を試してください。");
    }
};

window.handleQuizCancelOrEndAction = function() {
    // Aパターン：通常のクイズ画面なら、今まで通り一覧画面に戻すだけ
    if (!isDiagnosticMode) {
        if (typeof window.goBackToListFromQuiz === 'function') {
            window.goBackToListFromQuiz();
        }
        return;
    }

    // Bパターン：実力診断テスト中の場合 ➔ 💡【塾長のご指定ルール】その時点でクリアしているクラスを合格にする！
    const confirmEnd = confirm("ここで実力診断テストを終了し、現在のステージまでの結果で開始レベルを確定させますか？");
    if (!confirmEnd) return;

    // 現在の diagnosticStage (1=中1テスト中, 2=中2テスト中, 3=中3テスト中)
    // ➔ 例：stageが2の時点でこのボタンを押した＝「ステージ1（中1基礎）はすでに合格クリアしている」という意味になります！
    let finalLevelKey = "chui1"; 
    
    if (diagnosticStage === 1) {
        // 中1のテストの途中でやめた ➔ まだどこもクリアしていないので中1基礎からスタート
        finalLevelKey = "chui1";
    } else if (diagnosticStage === 2) {
        // 中2のテストの途中でやめた ➔ ステージ1（中1）は完全合格しているので、中2からスタート
        finalLevelKey = "chui2";
    } else if (diagnosticStage === 3) {
        // 中3のテストの途中でやめた ➔ ステージ2（中2）までは完全合格しているので、中3からスタート
        finalLevelKey = "chui3";
    }

    // 🚀 モードを解除し、確定関数をダイレクトに呼び出して「診断パス（青色）」を記録させてホームへ強制送還！
    if (typeof setFinalDiagnosticLevel === 'function') {
        setFinalDiagnosticLevel(finalLevelKey);
    } else {
        isDiagnosticMode = false;
        isReviewMode = false;
        window.showPage("homePage");
    }
};
    
// --- キーボード ---
const layouts = {
  mobile: [["a","b","c","d","e","f","g","h","i"],["j","k","l","m","n","o","p","q","r"],["shift","s","t","u","v","w","x","y","z","del"]],
  qwerty: [["q","w","e","r","t","y","u","i","o","p"],["a","s","d","f","g","h","j","k","l"],["shift","z","x","c","v","b","n","m","del"]]
};

function buildKeyboard() {
  const container = document.getElementById("keyboard");
  container.innerHTML = "";
  layouts[currentLayout].forEach(row => {
    const div = document.createElement("div");
    div.className = "key-row";
    row.forEach(key => {
      const btn = document.createElement("button");
      if (key === "shift") {
        btn.textContent = "↑"; btn.onclick = () => { upper = !upper; buildKeyboard(); };
      } else if (key === "del") {
        btn.textContent = "⌫"; btn.onclick = () => { document.getElementById("answerInput").value = document.getElementById("answerInput").value.slice(0, -1); };
      } else {
        const char = upper ? key.toUpperCase() : key;
        btn.textContent = char;
        btn.onclick = () => { document.getElementById("answerInput").value += char; if(upper){upper=false; buildKeyboard();} };
      }
      div.appendChild(btn);
    });
    container.appendChild(div);
  });
}

document.getElementById("keyboardSelect").onchange = (e) => {
  currentLayout = e.target.value;
  buildKeyboard();
};

window.renderListSectionSelect = function() {
    const listSelect = document.getElementById("listSectionSelect");
    if (!listSelect) return;

    // プルダウンを一度クリア
    listSelect.innerHTML = "";

    // 🟢 最上部に「全単語（全範囲）」の選択肢を追加
    const allOption = document.createElement("option");
    allOption.value = "all";
    allOption.textContent = "📖 全範囲単語マスター（1,006語）";
    if (isAllWordsMode) allOption.selected = true;
    listSelect.appendChild(allOption);

    // 🎨 レベルごとのグループ（見出し枠）を作成
    const g1 = document.createElement("optgroup"); g1.label = "🌱 【中1】基礎クラス（Sec 1 - 22）";
    const g2 = document.createElement("optgroup"); g2.label = "🌿 【中2】標準クラス（Sec 23 - 53）";
    const g3 = document.createElement("optgroup"); g3.label = "🔥 【中3】入試応用クラス（Sec 54 - 74）";
    const g4 = document.createElement("optgroup"); g4.label = "👑 【入試直前】最上位テーマ（Sec 75 - 101）";

    // 1,006語から全セクション数を計算（101個）
    const count = Math.ceil(words.length / SECTION_SIZE);
    
    for (let i = 1; i <= count; i++) {
        const opt = document.createElement("option");
        opt.value = i;
        opt.textContent = `Section ${i}`;
        
        // 現在開いているセクションなら初期選択状態にする
        if (!isAllWordsMode && i === currentSection) {
            opt.selected = true;
        }

        // 💡 セクション番号の根拠に基づいて、各グループの中に放り込む！
        if (i <= 22) {
            g1.appendChild(opt);
        } else if (i <= 53) {
            g2.appendChild(opt);
        } else if (i <= 74) {
            g3.appendChild(opt);
        } else {
            g4.appendChild(opt);
        }
    }

    // 完成した4つのグループをプルダウンに順番にドッキング
    listSelect.appendChild(g1);
    listSelect.appendChild(g2);
    listSelect.appendChild(g3);
    listSelect.appendChild(g4);
};
    
