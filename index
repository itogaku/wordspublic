// --- クイズロジック ---
window.startTodayLesson = async function() {
    if (!currentUser) return;

    if (isSuspended) {
        isSuspended = false; 
        isReviewMode = false;
        isSelfPracticeMode = false;
        window.isActualCheckTestMode = false;
        window.isTodayReviewTestMode = false;
        if (typeof resetQuizUI === 'function') resetQuizUI();
        
        const listSelect = document.getElementById("listSectionSelect");
        if (listSelect) {
            listSelect.value = isAllWordsMode ? "all" : currentSection;
            listSelect.disabled = true;
            listSelect.style.backgroundColor = "#e0e0e0"; 
        }
        
        document.querySelectorAll(".page").forEach(p => p.classList.remove("active"));
        const listPage = document.getElementById("list");
        if (listPage) listPage.classList.add("active");
        if (typeof window.renderList === 'function') window.renderList();

        const listQuizNav = document.getElementById("listQuizNav");
        const listHomeBackBtn = document.getElementById("listHomeBackBtn");
        if (listQuizNav) listQuizNav.style.display = "flex";
        if (listHomeBackBtn) listHomeBackBtn.style.display = "none";
        return; 
    }

    let uniquePool = [];
    if (isAllWordsMode) {
        uniquePool = [...words];
    } else {
        // 1. 苦手単語リスト（過去に間違えた単語）をプールに入れる
        if (reviewWrongWords && Array.isArray(reviewWrongWords)) {
            reviewWrongWords.forEach(w => {
                const sp = (typeof w === 'object' && w.word) ? w.word : String(w);
                const found = words.find(item => item.word.toLowerCase() === sp.toLowerCase());
                if(found) uniquePool.push(found);
            });
        }
        // 2. 直前に合格したセクションの単語を優先して復習に入れる
        if (lastCompletedSection > 0) {
            let start = (lastCompletedSection - 1) * SECTION_SIZE; 
            let priority2 = words.slice(start, start + SECTION_SIZE);
            priority2.forEach(w => {
                if (w && w.word && !uniquePool.some(p => p.word.toLowerCase() === w.word.toLowerCase())) {
                    uniquePool.push(w);
                }
            });
        }
        // 3. それでも足りない場合は既習単語からランダムに補充する
        if (uniquePool.length < TEST_QUESTION_COUNT) {
            let learnedWords = words.filter(w => {
                const hasProgress = progress[w.word.toLowerCase()] !== undefined;
                const isNotDuplicate = !uniquePool.some(p => p.word.toLowerCase() === w.word.toLowerCase());
                return hasProgress && isNotDuplicate;
            });
            learnedWords.sort(() => 0.5 - Math.random());
            for (let w of learnedWords) {
                if (uniquePool.length >= TEST_QUESTION_COUNT) break;
                uniquePool.push(w);
            }
        }
    }
    
    // 💡【重要追加】復習すべき単語が1問もない（初めての学習、または完全にすべての単語をマスターしている）場合
    if (uniquePool.length === 0) {
        alert(`【お知らせ】\n現在、復習が必要な単語はありません！✨\n\n今回は復習テストをスキップして、本日の学習範囲の暗記に進みます。\n\n※次回以降、テストで間違えた単語がある場合は、このボタンを押したときに自動で「復習テスト」が生成されてスタートします。`);
        
        // 復習テストはスキップして、そのまま今日のセクションの単語一覧画面へ流す
        window.exitToListViewFromReview();
        return;
    }

    // 🚀 問題がある場合は通常通りカウントを増やしてテストを開始
    studyCount++; 
    
    reviewPool = uniquePool.sort(() => 0.5 - Math.random()).slice(0, TEST_QUESTION_COUNT);
    testLog = [];
    isReviewMode = true;
    isSelfPracticeMode = false;
    isPracticeModeGlobal = false;
    window.isActualCheckTestMode = false;
    window.isTodayReviewTestMode = true;

    await saveProgress(); 
    if (typeof updateHomeDashboard === 'function') updateHomeDashboard();
    
    renderQuestion();
    window.showPage("quiz");
};

function getNextWord() {
  let start = (currentSection - 1) * SECTION_SIZE;
  let pool = words.slice(start, start + SECTION_SIZE);
  const unattempted = pool.filter(w => progress[w.word.toLowerCase()] === undefined);
  if (unattempted.length > 0) return unattempted[Math.floor(Math.random() * unattempted.length)];
  const wrongs = pool.filter(w => progress[w.word.toLowerCase()] === "wrong");
  return wrongs.length > 0 ? wrongs[Math.floor(Math.random() * wrongs.length)] : null;
}

function renderQuestion() {
  current = isReviewMode ? (reviewPool.pop() || null) : getNextWord();
  if (!current) { showTestResult(); return; }

  // 💡【新規追加】実力診断テスト中なら、下のボタンを「テストを終了する」に強制変更！
  const bottomBtn = document.getElementById("quizCancelOrEndBtn");
  if (bottomBtn) {
      if (isDiagnosticMode) {
          bottomBtn.innerHTML = "🏁 実力診断テストを終了する";
          bottomBtn.style.background = "#d32f2f"; // 緊張感のある警告の赤色
      } else {
          bottomBtn.innerHTML = "⬅️ 一覧に戻る";
          bottomBtn.style.background = "#555"; // 通常のグレー
      }
  }

  // --- 💡【塾用制限機能】最初の復習テスト中は、終了ボタン自体を完全に隠す（既存のまま維持） ---
  const quizBottomBackBtn = document.getElementById("quizCancelOrEndBtn");
  if (quizBottomBackBtn && quizBottomBackBtn.parentElement) {
      if (window.isTodayReviewTestMode === true) {
          quizBottomBackBtn.parentElement.style.display = "none";
      } else {
          quizBottomBackBtn.parentElement.style.display = "block";
      }
  }

  // (以下、既存の meaning や example の描画処理へとそのまま続きます)
  document.getElementById("meaning").textContent = current.meaning;
  document.getElementById("exampleEn").textContent = current.example || "";
  document.getElementById("exampleJa").textContent = current.exampleJa || "";
  document.getElementById("judge").textContent = "";
  document.getElementById("correctWord").textContent = "";
  document.getElementById("answerExample").textContent = "";
  document.getElementById("answerInput").value = "";
  document.getElementById("resultArea").className = "";
  document.getElementById("checkBtn").classList.remove("hidden");
  document.getElementById("nextBtn").classList.add("hidden");
}

// ボタンイベントのリスナー登録
document.getElementById("checkBtn").addEventListener("click", async () => {
    const val = document.getElementById("answerInput").value.trim().toLowerCase();
    const ok = val === current.word.toLowerCase();
    const status = ok ? "correct" : "wrong";
    
    testLog.push({ word: current.word, meaning: current.meaning, status: status });
    progress[current.word.toLowerCase()] = status;

    // 💡【追加】実力診断テストモード中なら、正解数をカウントアップする！
    if (isDiagnosticMode && status === "correct") {
        diagnosticStageCorrect++;
    }

    if (window.isTodayReviewTestMode === true) {
        if (!ok) {
            if (!reviewWrongWords.some(w => {
                const spell = (typeof w === 'object') ? w.word : w;
                return spell.toLowerCase() === current.word.toLowerCase();
            })) {
                reviewWrongWords.push(current.word.toLowerCase());
            }
        } else {
            reviewWrongWords = reviewWrongWords.filter(w => {
                const spell = (typeof w === 'object') ? w.word : w;
                return spell.toLowerCase() !== current.word.toLowerCase();
            });
        }
    }

    await saveProgress();

    const res = document.getElementById("resultArea");
    const j = document.getElementById("judge");
    j.textContent = ok ? "◎" : "✕";
    j.className = ok ? "correct-text" : "wrong-text";
    if (res) res.className = ok ? "correct" : "wrong";
    
    document.getElementById("correctWord").textContent = "答え: " + current.word;
    if (current.example) {
        document.getElementById("answerExample").textContent = current.example.replace(/_+/g, current.word);
    }
    document.getElementById("checkBtn").classList.add("hidden");
    document.getElementById("nextBtn").classList.remove("hidden");
});

document.getElementById("nextBtn").addEventListener("click", () => {
    if (isDiagnosticMode && reviewPool.length === 0) {
        showTestResult();
    } else {
        renderQuestion();
    }
});
function showTestResult() {
    isSuspended = false;

    // ========================================================
    // 🚀 【最優先割り込み】実力診断（サバイバルステージ）モードの判定処理
    // ========================================================
    if (isDiagnosticMode) {
        document.getElementById("quizQuestionArea").classList.add("hidden");
