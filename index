            listHtml += `<div style="color:${color}; border-bottom:1px solid #eee; padding:5px 0;">${mark} ${item.word} (${item.meaning})</div>`;
        });

        if (isStagePassed && diagnosticStage < 3) {
            // ========================================================
            // 🟢 ステージ1 または 2 を突破（合格）した場合
            // ========================================================
            
            // 💡【解決の核心1】「次へ」ボタンを押す前、このリザルト画面が出た瞬間に合格セクションを即時確定させる！
            if (!window.diagnosticPassedSections) window.diagnosticPassedSections = [];
            let endSectionForThisStage = (diagnosticStage === 1) ? 22 : 53;
            let startSectionForThisStage = (diagnosticStage === 1) ? 1 : 23;
            
            for (let s = startSectionForThisStage; s <= endSectionForThisStage; s++) {
                if (!window.diagnosticPassedSections.includes(s)) {
                    window.diagnosticPassedSections.push(s);
                }
            }
            // 目標位置も次のステージの先頭へ更新
            currentSection = endSectionForThisStage + 1;

            // 💡 該当範囲のwordsをすべて裏で「correct」に変える
            let recommendedIndex = (diagnosticStage === 1) ? 219 : 532;
            for (let i = 0; i < recommendedIndex; i++) {
                const w = words[i];
                if (w && w.word) progress[w.word.toLowerCase()] = "correct"; 
            }

            // 即時バックグラウンドセーブ
            try { if (typeof saveProgress === 'function') saveProgress(); } catch(e) { console.error(e); }

            const nextStageNum = diagnosticStage + 1;
            const currentStageName = diagnosticStage === 1 ? "【中1基礎】" : "【中2標準】";
            const nextStageName = nextStageNum === 2 ? "ステージ2【中2標準】" : "最終ステージ3【中3入試応用】";

            resultView.innerHTML = `
                <h3 id="resultTitle" style="color:#4caf50; margin-top:0; font-size:22px;">🌱 ステージ${diagnosticStage} ${currentStageName} クリア！</h3>
