window.goToQuizFromList = function(isPractice) {
    isSuspended = false;
    testLog = [];
    isReviewMode = true; 
    isPracticeModeGlobal = isPractice;
    isSelfPracticeMode = isPractice; 

    let offset = (currentSection - 1) * SECTION_SIZE;
    let sectionPool = words.slice(offset, offset + SECTION_SIZE);
    
    let wrongSpells = reviewWrongWords.map(w => (typeof w === 'object' && w.word) ? w.word : String(w));
    let combined = [...sectionPool];
    
    wrongSpells.forEach(spell => {
        const foundWord = words.find(x => x.word.toLowerCase() === spell.toLowerCase());
        if (foundWord && !combined.some(c => c.word.toLowerCase() === spell.toLowerCase())) {
            combined.push(foundWord);
        }
    });

    if (isPractice) {
        combined = combined.filter(w => progress[w.word.toLowerCase()] !== "correct");
        if (combined.length === 0) { alert("未習得の単語はありません！"); return; }
        reviewPool = combined.sort(() => Math.random() - 0.5).slice(0, TEST_QUESTION_COUNT);
        window.isActualCheckTestMode = false;
        window.isTodayReviewTestMode = false;
    } else {
        // チェックテスト：復習単語を混ぜつつ、出題数を設定サイズでカチッと固定
        reviewPool = combined.sort(() => Math.random() - 0.5).slice(0, TEST_QUESTION_COUNT);
        window.isActualCheckTestMode = true; 
        window.isTodayReviewTestMode = false;
    }

    renderQuestion();
    showPage("quiz");
};

