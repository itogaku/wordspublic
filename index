window.renderList = function() {
    const table = document.getElementById("wordTable");
    const filter = document.getElementById("filter").value;
    let currentLevelHeaderHtml = "";

    if (!isAllWordsMode) {
        const sampleNum = (currentSection - 1) * SECTION_SIZE + 1;
        const info = getLevelInfoByNumber(sampleNum); // 💡1番の関数をここで使っています！
        currentLevelHeaderHtml = `
            <tr>
                <td colspan="4" style="background: ${info.bg}; color: ${info.color}; padding: 15px; text-align: center; border-radius: 8px;">
                    <div style="font-weight: bold; font-size: 18px;">${info.text}</div>
                    <div style="font-size: 13px; margin-top: 4px; opacity: 0.8;">${info.sub} ─── (Section ${currentSection})</div>
                </td>
            </tr>
            <tr><td colspan="4" style="height:10px; background:transparent; border:none;"></td></tr>
        `;
    } else {
        currentLevelHeaderHtml = `<tr><td colspan="4" style="background:#f5f5f7; color:#333; font-weight:bold; text-align:center; padding:12px;">📖 全範囲単語マスター（1,006語）</td></tr>`;
    }

    table.innerHTML = currentLevelHeaderHtml + "<tr><th>No</th><th>単語</th><th>意味</th><th>状態</th></tr>";

    if (!isAllWordsMode && typeof reviewWrongWords !== 'undefined' && reviewWrongWords && reviewWrongWords.length > 0 && filter !== "correct") {
        let hasDisplayedHeader = false;
        reviewWrongWords.forEach(w => {
            if (!w) return;
            const spell = (typeof w === 'object' && w.word) ? w.word : String(w);
            const foundIndex = words.findIndex(x => x && x.word && x.word.toLowerCase() === spell.toLowerCase());
            if (foundIndex === -1) return;
            const found = words[foundIndex];

            if (!hasDisplayedHeader) {
                table.innerHTML += `<tr><td colspan="4" style="background:#fff3e0; color:#e65100; font-weight:bold; text-align:center;">⚠️ 復習が必要な単語</td></tr>`;
                hasDisplayedHeader = true;
            }

            const state = progress[spell.toLowerCase()];
            const info = getLevelInfoByNumber(foundIndex + 1); // 💡1番の関数をここでも使っています！
            const badgeHtml = `<span style="background: ${info.bg}; color: ${info.color}; font-size: 11px; font-weight: bold; padding: 2px 6px; border-radius: 4px; margin-right: 6px;">${info.text.split('】')[1]}</span>`;

            table.innerHTML += `<tr style="background:#fff9f0;"><td>!</td><td>${badgeHtml}<strong>${spell}</strong></td><td>${found.meaning || "-"}</td><td style="text-align:center">${state==='correct'?'〇':'×'}</td></tr>`;
        });
    }
    
    let pool = [];
    let offset = 0;
    if (isAllWordsMode) { pool = words; } else { offset = (currentSection - 1) * SECTION_SIZE; if (offset < words.length) { pool = words.slice(offset, offset + SECTION_SIZE); } else { pool = []; } }

    let lastDisplayedLevel = "";
    pool.forEach((w, index) => {
        if (!w || !w.word) return;
        const state = progress[w.word.toLowerCase()];
        if (filter === "correct" && state !== "correct") return;
        if (filter === "wrong" && state !== "wrong") return;
        
        const displayIndex = isAllWordsMode ? (index + 1) : (offset + index + 1);
        const info = getLevelInfoByNumber(displayIndex); // 💡1番の関数をここでも使っています！

        if (isAllWordsMode && lastDisplayedLevel !== info.text) {
            table.innerHTML += `
                <tr><td colspan="4" style="height:15px; background:transparent; border:none;"></td></tr>
                <tr><td colspan="4" style="background: ${info.bg}; color: ${info.color}; font-weight:bold; text-align:center; padding:10px; border-top:2px solid ${info.color};">${info.text}（ここから）</td></tr>
            `;
            lastDisplayedLevel = info.text;
        }
        
        const shortLevelName = info.text.split('】')[1] || info.text;
        const badgeHtml = `<span style="background: ${info.bg}; color: ${info.color}; font-size: 11px; font-weight: bold; padding: 2px 6px; border-radius: 4px; margin-right: 6px; display: inline-block; vertical-align: middle;">${shortLevelName}</span>`;

        table.innerHTML += `<tr><td>${displayIndex}</td><td>${badgeHtml}<strong>${w.word}</strong></td><td>${w.meaning || "-"}</td><td style="text-align:center">${state==='correct'?'〇':state==='wrong'?'×':'-'}</td></tr>`;
    });
};
