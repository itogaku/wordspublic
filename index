        currentUser = savedName;
        await loadUserData(); // ローカルからデータ展開
        
        if (typeof window.renderListSectionSelect === 'function') {
            window.renderListSectionSelect();
        }
        
        updateHomeDashboard();
        window.showPage("homePage");
    } else {
        window.showPage("userPage");
    }
}
