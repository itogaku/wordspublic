window.startGlobalSampleTest = function() {
    const N = words.length;
    if (N === 0) return alert("単語データが登録されていません。");

    const z = 1.96;
    const e = 0.05;
    const p = 0.5;
    
    const numerator = (z * z) * p * (1 - p);
    const denominator = (e * e) + (numerator / N);
    let sampleSize = Math.ceil(numerator / denominator);
    
    if (sampleSize > N) sampleSize = N;
    if (sampleSize < 5 && N >= 5) sampleSize = 5;

    if (!confirm(`【全範囲実力テスト】\n\n全範囲からあなたの現在の実力を測定します。\n全 ${N} 語の中から【 ${sampleSize} 問 】をランダムに選んでテストを行います。挑戦しますか？`)) {
        return;
    }

    testLog = [];
    isReviewMode = true; 
    isSelfPracticeMode = true;
    isPracticeModeGlobal = true; 

    reviewPool = [...words].sort(() => Math.random() - 0.5).slice(0, sampleSize);
    
    renderQuestion();
    showPage("quiz");
};

