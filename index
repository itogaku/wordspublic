                <p style="margin-bottom:20px; color:#666; font-size:14px; padding:0 10px;">
                    基準（8割）をクリアしました！上のレベルへ昇格します。<br>
                    次は <strong>${nextStageName}</strong> に挑戦です！
                </p>
                <button id="diagnosticNextStageActionBtn" class="btn-primary" style="width: 100%; height: 50px; background: #9c27b0; font-size:16px; border:none; border-radius:6px; font-weight:bold; box-shadow: 0 4px 12px rgba(156,39,176,0.25);">
                    🔥 次のステージのテストを開始する
                </button>
            `;
            document.getElementById("diagnosticNextStageActionBtn").onclick = () => {
                handleDiagnosticStageClear();
            };

        } else {
            // ========================================================
            // 🔴 不合格、または 👑 ステージ3（最終）も完全制覇した場合
            // ========================================================
            let recommendedIndex = 0;
            let className = "";

            if (isStagePassed) {
                // ステージ3クリア
                recommendedIndex = 735; className = "【入試直前・最上位】";
                if (!window.diagnosticPassedSections) window.diagnosticPassedSections = [];
                for (let s = 1; s <= 74; s++) {
                    if (!window.diagnosticPassedSections.includes(s)) window.diagnosticPassedSections.push(s);
                }
            } else {
                // 途中で不合格
                if (diagnosticStage === 1) { recommendedIndex = 0; className = "【中1・基礎】"; }
                else if (diagnosticStage === 2) { recommendedIndex = 219; className = "【中2・標準】"; }
                else { recommendedIndex = 532; className = "【中3・入試応用】"; }
            }

            for (let i = 0; i < recommendedIndex; i++) {
                const w = words[i];
                if (w && w.word) progress[w.word.toLowerCase()] = "correct"; 
            }
            currentSection = Math.floor(recommendedIndex / 10) + 1;

            const titleColor = isStagePassed ? "#ff9800" : "#c62828";
            const titleText = isStagePassed ? "👑 全ステージ完全制覇！ 👑" : "🏁 実力診断テスト終了";
            const subMessage = isStagePassed 
                ? `中1〜中3すべての防衛ラインを突破しました！最難関の「最上位テーマ」クラスに配属します。`
                : `ステージ${diagnosticStage}にて終了となりました。あなたの学力に最適な位置からスタートします。`;

            resultView.innerHTML = `
                <h3 id="resultTitle" style="color:${titleColor}; margin-top:0; font-size:22px;">${titleText}</h3>
